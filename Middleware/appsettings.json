{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore.HttpLogging.HttpLoggingMiddleware": "Information"
    }
  },
  "AllowedHosts": "*",
  "SimpleCaching": {
    "CacheablePaths": [ "/test/time", "/test/data" ],
    "CacheDurationSeconds": 10,
    "CacheKeyPrefix": "caching_"
  },
  "SimpleRateLimiter": {
    "IntervalSeconds": 5,
    "ClientIdentifierHeader": "IP",
    "CacheKeyPrefix": "rateLimiting_"
  }
}
